# BMFFFL Website Environment Variables
# Copy to .env.local and fill in values

# Sleeper League ID (required)
# Find at: sleeper.com → your league → URL bar
NEXT_PUBLIC_SLEEPER_LEAGUE_ID=910140889474326528

# Site URL (optional, for SEO/sitemap)
NEXT_PUBLIC_SITE_URL=https://bmfffl.vercel.app

# Convex URL (server-side only, used in getStaticProps at build time)
# Prod: https://graceful-grasshopper-238.convex.cloud
# Dev:  https://resolute-setter-416.convex.cloud
CONVEX_URL=https://graceful-grasshopper-238.convex.cloud
